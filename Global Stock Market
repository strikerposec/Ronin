function updateSum(){
  const qty=parseInt(document.getElementById('qtyInp').value)||0;
  const p=effectivePrice(selSym);
  const sub=qty*p,fee=sub*0.001,grand=sub+(tradeMode==='buy'?fee:-fee);
  const owned=(holdings[selSym]||{shares:0}).shares;
  document.getElementById('tradeSummary').innerHTML=`
    <div class="sum-row"><span>Price/share</span><span>$${fmt(p)}</span></div>
    <div class="sum-row"><span>Quantity</span><span>${qty.toLocaleString()}</span></div>
    <div class="sum-row"><span>Subtotal</span><span>$${fmt(sub)}</span></div>
    <div class="sum-row"><span>Commission (0.1%)</span><span>$${fmt(fee)}</span></div>
    <div class="sum-row total"><span>Total</span><span>$${fmt(grand)}</span></div>`;
  const ok=tradeMode==='buy'?grand<=cash:qty<=owned;
  const btn=document.getElementById('execBtn');
  btn.disabled=qty<=0||!ok;
  btn.textContent=`EXECUTE ${tradeMode.toUpperCase()}`;
  btn.className='exec-btn '+tradeMode;
}
function setQty(n){document.getElementById('qtyInp').value=n;updateSum();}
function setTradeMode(m,btn){
  tradeMode=m;
  document.querySelectorAll('.trade-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  updateSum();
}
function executeTrade(){
  const qty=parseInt(document.getElementById('qtyInp').value)||0;
  const p=effectivePrice(selSym);
  const sub=qty*p,fee=sub*0.001;
  const startYear=simMode==='historic'?1920:1980;
  const d=new Date(startYear+Math.floor(Math.random()*(simMode==='historic'?59:39)),Math.floor(Math.random()*12),1+Math.floor(Math.random()*27));
  const dateStr=d.toISOString().slice(0,10);
  if(tradeMode==='buy'){
    const cost=sub+fee;
    if(cost>cash){toast('Insufficient Funds',`Need $${fmt(cost)}, have $${fmt(cash)}`,'err');return;}
    cash-=cost;
    if(!holdings[selSym])holdings[selSym]={shares:0,avgCost:0};
    const h=holdings[selSym];
    h.avgCost=(h.avgCost*h.shares+p*qty)/(h.shares+qty);
    h.shares+=qty;
    transactions.unshift({sym:selSym,type:'BUY',qty,price:p,total:cost,date:dateStr});
    toast(`Bought ${qty} ${selSym}`,`$${fmt(cost)} deducted`);
  } else {
    const h=holdings[selSym];
    if(!h||h.shares<qty){toast('Insufficient Shares',`Own ${h?h.shares:0}`,'err');return;}
    const proceeds=sub-fee;
    cash+=proceeds;
    h.shares-=qty;
    if(!h.shares)delete holdings[selSym];
    transactions.unshift({sym:selSym,type:'SELL',qty,price:p,total:proceeds,date:dateStr});
    toast(`Sold ${qty} ${selSym}`,`$${fmt(proceeds)} received`);
  }
  portHistory.push(portValue());
  renderAll();
}

