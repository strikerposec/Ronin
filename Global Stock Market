function basePrice(sym){const p=currentPrices()[sym];return p[p.length-1];}
function effectivePrice(sym){
  let mult=1;
  Object.values(currentRegs()).forEach(c=>{
    c.regs.forEach(r=>{if(r.active&&r.impacts&&r.impacts[sym])mult+=r.impacts[sym].pct/100;});
  });
  return Math.max(0.01,basePrice(sym)*mult);
}
function prevPrice(sym){const p=currentPrices()[sym];return p[p.length-2];}
function pctChg(sym){const c=effectivePrice(sym),pp=prevPrice(sym);return(c-pp)/pp*100;}
function portValue(){
  let v=cash;
  Object.entries(holdings).forEach(([sym,h])=>{if(h.shares>0)v+=h.shares*effectivePrice(sym);});
  return v;
}

