function renderHoldings(){
  const el=document.getElementById('holdingsList');
  const entries=Object.entries(holdings).filter(([,h])=>h.shares>0);
  if(!entries.length){el.innerHTML='<div class="empty-state">No open positions</div>';return;}
  el.innerHTML=entries.map(([sym,h])=>{
    const p=effectivePrice(sym),val=h.shares*p,pnl=val-h.shares*h.avgCost,pnlP=pnl/(h.shares*h.avgCost)*100;
    return`<div class="holding-row"><div class="h-sym">${sym}</div><div class="h-inf"><div class="h-shares">${h.shares.toLocaleString()} shares</div><div class="h-cost">avg $${fmt(h.avgCost)}</div></div><div class="h-right"><div class="h-val">$${fmtK(val)}</div><div class="h-pnl ${cls(pnl)}">${sgn(pnlP)}${pnlP.toFixed(1)}%</div></div></div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════
//  REGULATIONS PANEL
// ═══════════════════════════════════════════════════
function renderRegPanel(){
  let count=0;
  Object.values(currentRegs()).forEach(c=>c.regs.forEach(r=>{if(r.active)count++;}));
  document.getElementById('activeRegCount').textContent=`${count} active`;
  const el=document.getElementById('regPanel');
  el.innerHTML=Object.entries(currentRegs()).map(([key,c])=>{
    const actN=c.regs.filter(r=>r.active).length;
    const regsHtml=c.regs.map(r=>{
      const impHtml=r.impacts?Object.entries(r.impacts).map(([sym,imp])=>`<div class="imp-row"><span class="imp-sym">${sym}</span><span class="imp-val ${imp.dir}">${sgn(imp.pct)}${imp.pct.toFixed(1)}%</span></div>`).join(''):'';
      return`<div class="reg-item">
        <div class="reg-item-top"><span class="reg-name">${r.name}</span>
          <label class="reg-toggle"><input type="checkbox" ${r.active?'checked':''} onchange="toggleReg('${key}','${r.id}',this.checked)"><div class="tog-track"></div><div class="tog-thumb"></div></label>
        </div>
        <div class="reg-desc">${r.desc}</div>
        <div class="reg-impacts">${impHtml}</div>
      </div>`;
    }).join('');
    return`<div class="c-section">
      <div class="c-hdr" onclick="toggleCountry('${key}')">
        <span class="c-flag">${c.flag}</span><span class="c-name">${c.name}</span>
        ${actN?`<span class="c-act-count">${actN} active</span>`:''}
        <span class="c-arr" id="carr-${key}">›</span>
      </div>
      <div class="reg-list" id="clist-${key}">${regsHtml}</div>
    </div>`;
  }).join('');
}
function toggleCountry(key){
  const l=document.getElementById('clist-'+key);
  const a=document.getElementById('carr-'+key);
  const o=l.classList.toggle('open');
  a.classList.toggle('open',o);
}
function toggleReg(cKey,rId,val){
  const c=currentRegs()[cKey];
  if(!c)return;
  const r=c.regs.find(x=>x.id===rId);
  if(!r)return;
  r.active=val;
  const n=r.impacts?Object.keys(r.impacts).length:0;
  toast(val?'Regulation Activated':'Regulation Deactivated',`${r.name} — ${n} stock${n!==1?'s':''} affected`,val?'warn':'');
  renderAll();
}

// ═══════════════════════════════════════════════════
//  PORTFOLIO
// ═══════════════════════════════════════════════════
function renderPortfolio(){
  const total=portValue(),gain=total-100000,inv=total-cash;
  const unreal=Object.entries(holdings).reduce((a,[sym,h])=>h.shares>0?a+h.shares*(effectivePrice(sym)-h.avgCost):a,0);
  function psc(l,v,s,sc){return`<div class="psc"><div class="psc-l">${l}</div><div class="psc-v">${v}</div>${s?`<div class="psc-s ${sc||''}">${s}</div>`:''}</div>`;}
  document.getElementById('portStatsRow').innerHTML=
    psc('Total Value','$'+fmt(total),sgn(gain)+'$'+fmt(Math.abs(gain)),cls(gain))+
    psc('Cash','$'+fmt(cash))+psc('Invested','$'+fmt(inv))+
    psc('Unrealized P&L',(unreal>=0?'+':'')+fmt(unreal),(unreal/100000*100).toFixed(2)+'%',cls(unreal));
  const hist=portHistory.length>1?portHistory:[100000,total];
  const ctx=document.getElementById('portChart');
  if(portChartInst)portChartInst.destroy();
  const lc=simMode==='historic'?'#c9a84c':'#3b82f6';
  portChartInst=new Chart(ctx,{type:'line',data:{labels:hist.map((_,i)=>i===0?'Start':`T${i}`),datasets:[{data:hist,borderColor:lc,backgroundColor:lc.replace(')',', 0.07)').replace('rgb','rgba').replace('#c9a84c','rgba(201,168,76,0.07)').replace('#3b82f6','rgba(59,130,246,0.07)'),fill:true,tension:0.3,pointRadius:1.5,borderWidth:2}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#4a5568',font:{size:10}},grid:{color:'#1e2433'}},y:{ticks:{color:'#4a5568',font:{size:10},callback:v=>'$'+fmtK(v)},grid:{color:'#1e2433'}}}}});
  const entries=Object.entries(holdings).filter(([,h])=>h.shares>0);
  const posEl=document.getElementById('posTable');
  if(!entries.length){posEl.innerHTML='<div class="empty-state">No open positions. Start trading to build your portfolio.</div>';}
  else posEl.innerHTML=`<table class="ptable"><thead><tr><th>Symbol</th><th>Shares</th><th>Avg Cost</th><th>Price</th><th>Value</th><th>P&L</th></tr></thead><tbody>${entries.map(([sym,h])=>{const p=effectivePrice(sym),val=h.shares*p,pnl=val-h.shares*h.avgCost;return`<tr><td><strong>${sym}</strong></td><td>${h.shares.toLocaleString()}</td><td>$${fmt(h.avgCost)}</td><td>$${fmt(p)}</td><td>$${fmt(val)}</td><td class="${cls(pnl)}">${sgn(pnl)}$${fmt(Math.abs(pnl))}</td></tr>`;}).join('')}</tbody></table>`;
  const txEl=document.getElementById('txTable');
  if(!transactions.length){txEl.innerHTML='<div class="empty-state">No transactions yet.</div>';}
  else txEl.innerHTML=`<table class="ptable"><thead><tr><th>Date</th><th>Type</th><th>Symbol</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead><tbody>${transactions.slice(0,30).map(t=>`<tr><td style="color:var(--text2)">${t.date}</td><td><span style="font-size:9px;font-weight:700;padding:2px 7px;border-radius:3px;background:${t.type==='BUY'?'var(--green-dim)':'var(--red-dim)'};color:${t.type==='BUY'?'var(--green-lt)':'var(--red-lt)'}">${t.type}</span></td><td><strong>${t.sym}</strong></td><td>${t.qty.toLocaleString()}</td><td>$${fmt(t.price)}</td><td>$${fmt(t.total)}</td></tr>`).join('')}</tbody></table>`;
}

// ═══════════════════════════════════════════════════
//  LEADERBOARD
// ═══════════════════════════════════════════════════
const HIST_LB=[{n:'Margaret Pearce',v:148200},{n:'Heinrich Braun',v:141700},{n:'Kenji Watanabe',v:132400},{n:'Clara Dubois',v:124100},{n:'Stanislaw Kowalski',v:118300},{n:'Nora Fitzgerald',v:112800},{n:'Emilio Rossi',v:107400},{n:'Vera Novak',v:99200},{n:'Arthur Blackwood',v:96800}];
const MOD_LB=[{n:'Chen Wei',v:152300},{n:'Sofia Reyes',v:141800},{n:'Arjun Patel',v:133200},{n:'Emma Larsson',v:126400},{n:"James O'Brien",v:119700},{n:'Yuki Tanaka',v:113200},{n:'Fatima Hassan',v:108100},{n:'Lucas Becker',v:101400},{n:'Priya Sharma',v:97900}];
function renderLeaderboard(){
  const others=simMode==='historic'?HIST_LB:MOD_LB;
  const my=portValue();
  const all=[...others.map(t=>({name:t.n,val:t.v,me:false})),{name:'You',val:my,me:true}];
  all.sort((a,b)=>b.val-a.val);
  const top=all[0].val;
  const medal=['#c9a84c','#a8a9ad','#cd7f32'];
  document.getElementById('lbTitle').textContent=simMode==='historic'?'Historic Era Leaderboard (1920–1979)':'Modern Era Leaderboard (1980–2019)';
  document.getElementById('lbList').innerHTML=all.map((t,i)=>`<div class="lb-row">
    <div class="lb-rank" style="color:${i<3?medal[i]:'var(--text3)'}">${i+1}</div>
    <div class="lb-av" style="background:${t.me?'var(--accent-dim)':'var(--surface2)'};color:${t.me?'var(--accent-lt)':'var(--text2)'}">${t.name.substring(0,2).toUpperCase()}</div>
    <div class="lb-nw">
      <div class="lb-name">${t.name}${t.me?'<span class="you-tag">YOU</span>':''}</div>
      <div class="lb-bar-w"><div class="lb-bar-f" style="width:${(t.val/top*100).toFixed(1)}%;background:${i<3?medal[i]:'var(--accent)'}"></div></div>
    </div>
    <div class="lb-amt" style="color:${t.me?'var(--accent-lt)':'var(--text)'}">$${fmt(t.val)}</div>
  </div>`).join('');
}

// ═══════════════════════════════════════════════════
//  SELECT STOCK
// ═══════════════════════════════════════════════════
function selectStock(sym){
  selSym=sym;
  renderStockList();
  renderStockHeader(sym);
  renderChart(sym);
  renderRegImpact(sym);
  updateSum();
}

// ═══════════════════════════════════════════════════
//  RENDER ALL
// ═══════════════════════════════════════════════════
function renderAll(){
  document.getElementById('cashDisp').textContent='$'+fmt(cash);
  renderTicker();
  renderStockList();
  renderHoldings();
  renderRegPanel();
  renderStockHeader(selSym);
  renderChart(selSym);
  renderRegImpact(selSym);
  renderTFBtns();
  updateSum();
}

