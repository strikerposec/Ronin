function getSlice(sym){
  const all=currentPrices()[sym];
  const total=currentWeeks();
  const yearsPerWeek=simMode==='historic'?60:40;
  const map={'1Y':52,'5Y':260,'10Y':520,'20Y':1040,'All':total};
  const n=map[tf]||260;
  return all.slice(Math.max(0,all.length-n));
}
function renderChart(sym){
  const raw=getSlice(sym);
  const regMult=getRegMult(sym);
  const prices=raw.map((p,i)=>i===raw.length-1?p*regMult:p);
  const svg=document.getElementById('priceChart');
  const W=600,H=140,pt={t:8,b:18,l:6,r:6};
  const iW=W-pt.l-pt.r,iH=H-pt.t-pt.b;
  const min=Math.min(...prices)*0.994,max=Math.max(...prices)*1.006;
  const xs=prices.map((_,i)=>pt.l+(i/(prices.length-1))*iW);
  const ys=prices.map(p=>pt.t+iH-((p-min)/(max-min))*iH);
  const up=prices[prices.length-1]>=prices[0];
  const col=simMode==='historic'?(up?'#c9a84c':'#ef4444'):(up?'#10b981':'#ef4444');
  const pts=xs.map((x,i)=>`${x.toFixed(1)},${ys[i].toFixed(1)}`).join(' ');
  const bot=pt.t+iH;
  const id='g'+sym+Date.now();
  svg.innerHTML=`<defs><linearGradient id="${id}" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${col}" stop-opacity=".18"/><stop offset="100%" stop-color="${col}" stop-opacity="0"/></linearGradient></defs>
  <polygon points="${pt.l},${bot} ${pts} ${pt.l+iW},${bot}" fill="url(#${id})"/>
  <polyline points="${pts}" fill="none" stroke="${col}" stroke-width="1.5"/>
  <text x="${pt.l}" y="${H-3}" fill="#4a5568" font-size="9" font-family="IBM Plex Mono">$${fmtK(min)}</text>
  <text x="${W-pt.r}" y="${H-3}" fill="#4a5568" font-size="9" font-family="IBM Plex Mono" text-anchor="end">$${fmtK(max)}</text>`;
}
function getRegMult(sym){
  let m=1;
  Object.values(currentRegs()).forEach(c=>c.regs.forEach(r=>{
    if(r.active&&r.impacts&&r.impacts[sym])m+=r.impacts[sym].pct/100;
  }));
  return m;
}

