function genPrices(s, n, crashEvents) {
  const p=[]; let v=s.base;
  let seed=s.sym.charCodeAt(0)*17+(s.sym.charCodeAt(1)||7)*31;
  function rnd(){seed=(seed*1664525+1013904223)&0xffffffff;return(seed>>>0)/0xffffffff;}
  const trend=0.0006+rnd()*0.0012;
  for(let i=0;i<n;i++){
    let shock=0;
    if(crashEvents){
      crashEvents.forEach(e=>{
        if(i>=e.start&&i<e.start+e.duration){
          shock+=e.magnitude*(1-((i-e.start)/e.duration))*0.5;
        }
      });
    }
    v=v*(1+trend+(rnd()-0.48)*s.vol*2+shock);
    p.push(Math.max(0.01,parseFloat(v.toFixed(4))));
  }
  return p;
}

