<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MarketX — Century of Markets</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#08090d;--surface:#0f1117;--surface2:#151821;--surface3:#1a1e28;
  --border:#1e2433;--border2:#252d3d;
  --text:#e2e8f0;--text2:#8892a4;--text3:#4a5568;
  --accent:#2563eb;--accent-lt:#3b82f6;--accent-dim:rgba(37,99,235,0.12);
  --green:#059669;--green-lt:#10b981;--green-dim:rgba(5,150,105,0.12);
  --red:#dc2626;--red-lt:#ef4444;--red-dim:rgba(220,38,38,0.12);
  --amber:#d97706;--amber-lt:#f59e0b;--amber-dim:rgba(217,119,6,0.15);
  --sepia:#c9a84c;--sepia-dim:rgba(201,168,76,0.12);
  --font-d:'Syne',sans-serif;--font-b:'DM Sans',sans-serif;--font-m:'IBM Plex Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);font-size:14px;line-height:1.6;overflow-x:hidden}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}
.page{display:none;min-height:100vh}.page.active{display:block}

/* ─── SHARED NAV ─── */
.nav{position:fixed;top:0;left:0;right:0;z-index:300;padding:0 40px;height:54px;display:flex;align-items:center;gap:24px;background:rgba(8,9,13,0.88);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:var(--font-d);font-size:17px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px;cursor:pointer;letter-spacing:-0.3px}
.logo-dot{width:8px;height:8px;border-radius:50%;background:var(--accent-lt)}
.nav-links{display:flex;gap:2px}
.nav-lnk{background:none;border:none;color:var(--text2);font-family:var(--font-b);font-size:13px;padding:6px 13px;cursor:pointer;border-radius:5px;transition:all .15s}
.nav-lnk:hover{color:var(--text);background:var(--surface2)}
.nav-cta{background:var(--accent);color:#fff;border:none;font-family:var(--font-b);font-size:13px;font-weight:500;padding:7px 18px;border-radius:5px;cursor:pointer;transition:all .2s;margin-left:auto}
.nav-cta:hover{background:#1d4ed8;transform:translateY(-1px)}

/* ─── LANDING ─── */
.grid-bg{position:fixed;inset:0;pointer-events:none;z-index:0;background-image:linear-gradient(rgba(37,99,235,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,.025) 1px,transparent 1px);background-size:64px 64px}

.hero{position:relative;z-index:1;padding:130px 40px 60px;max-width:1120px;margin:0 auto}
.hero-eyebrow{font-family:var(--font-m);font-size:11px;color:var(--accent-lt);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:18px;display:flex;align-items:center;gap:10px}
.hero-eyebrow::before{content:'';width:32px;height:1px;background:var(--accent-lt)}
.hero-h1{font-family:var(--font-d);font-size:clamp(42px,5.5vw,76px);font-weight:800;line-height:1.04;letter-spacing:-2.5px;margin-bottom:22px}
.hero-h1 .blue{color:var(--accent-lt)}
.hero-h1 .dim{color:var(--text3)}
.hero-sub{font-size:17px;color:var(--text2);max-width:520px;line-height:1.75;margin-bottom:38px;font-weight:300}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:60px}
.btn-pri{background:var(--accent);color:#fff;border:none;font-family:var(--font-b);font-size:14px;font-weight:500;padding:13px 28px;border-radius:6px;cursor:pointer;transition:all .2s}
.btn-pri:hover{background:#1d4ed8;transform:translateY(-2px)}
.btn-sec{background:transparent;color:var(--text);border:1px solid var(--border2);font-family:var(--font-b);font-size:14px;padding:13px 28px;border-radius:6px;cursor:pointer;transition:all .2s}
.btn-sec:hover{border-color:var(--text3);background:var(--surface2)}

/* Era cards on landing */
.era-row{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:1120px;margin:0 auto;padding:0 40px 80px;position:relative;z-index:1}
.era-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:28px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.era-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;opacity:0;transition:opacity .3s}
.era-card.historic::after{background:linear-gradient(90deg,var(--sepia),var(--amber-lt));opacity:.6}
.era-card.modern::after{background:linear-gradient(90deg,var(--accent),var(--green-lt));opacity:.6}
.era-card:hover{transform:translateY(-3px);border-color:var(--border2)}
.era-badge{display:inline-flex;align-items:center;gap:7px;padding:5px 12px;border-radius:4px;font-family:var(--font-m);font-size:10px;font-weight:500;letter-spacing:1px;margin-bottom:16px}
.era-badge.hist{background:var(--sepia-dim);color:var(--sepia);border:1px solid rgba(201,168,76,.25)}
.era-badge.mod{background:var(--accent-dim);color:var(--accent-lt);border:1px solid rgba(37,99,235,.25)}
.era-title{font-family:var(--font-d);font-size:26px;font-weight:700;letter-spacing:-0.8px;margin-bottom:10px}
.era-sub{font-size:13px;color:var(--text2);line-height:1.65;font-weight:300;margin-bottom:20px}
.era-tags{display:flex;gap:8px;flex-wrap:wrap}
.era-tag{font-size:11px;padding:4px 10px;border-radius:3px;background:var(--surface2);color:var(--text3);border:1px solid var(--border);font-family:var(--font-m)}
.era-arrow{position:absolute;right:24px;top:50%;transform:translateY(-50%);font-size:22px;color:var(--text3);transition:all .2s}
.era-card:hover .era-arrow{color:var(--text);transform:translateY(-50%) translateX(4px)}

/* Timeline strip */
.timeline-strip{position:relative;z-index:1;padding:60px 40px;max-width:1120px;margin:0 auto;border-top:1px solid var(--border)}
.tl-label{font-family:var(--font-m);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:32px}
.tl-track{position:relative;padding:20px 0}
.tl-line{position:absolute;top:50%;left:0;right:0;height:1px;background:linear-gradient(90deg,var(--border),var(--border2),var(--border))}
.tl-events{display:flex;justify-content:space-between;position:relative;z-index:1}
.tl-event{text-align:center;flex:1;cursor:default}
.tl-dot{width:10px;height:10px;border-radius:50%;margin:0 auto 8px;border:2px solid}
.tl-dot.crash{background:var(--red-dim);border-color:var(--red-lt)}
.tl-dot.boom{background:var(--green-dim);border-color:var(--green-lt)}
.tl-dot.reg{background:var(--amber-dim);border-color:var(--amber-lt)}
.tl-year{font-family:var(--font-m);font-size:10px;color:var(--text3)}
.tl-evt-name{font-size:10px;color:var(--text2);margin-top:4px;line-height:1.3}

/* Features */
.features{position:relative;z-index:1;padding:60px 40px;max-width:1120px;margin:0 auto;border-top:1px solid var(--border)}
.sec-label{font-family:var(--font-m);font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--text3);margin-bottom:12px}
.sec-title{font-family:var(--font-d);font-size:34px;font-weight:700;letter-spacing:-1px;margin-bottom:40px;line-height:1.2}
.feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.feat-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:22px;transition:border-color .2s}
.feat-card:hover{border-color:var(--border2)}
.feat-ico{font-size:22px;margin-bottom:14px}
.feat-title{font-family:var(--font-d);font-size:15px;font-weight:600;margin-bottom:7px}
.feat-desc{font-size:12px;color:var(--text2);line-height:1.65;font-weight:300}

footer{border-top:1px solid var(--border);padding:24px 40px;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1}
.foot-logo{font-family:var(--font-d);font-size:14px;font-weight:700;color:var(--text3)}
.foot-note{font-size:12px;color:var(--text3);font-weight:300}

/* ─── SIMULATOR SHELL ─── */
#page-sim{background:var(--bg)}
.sim-topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:0 14px;height:46px;display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:200}
.sim-logo-btn{font-family:var(--font-d);font-size:14px;font-weight:800;cursor:pointer;display:flex;align-items:center;gap:6px;color:var(--text);border:none;background:none;flex-shrink:0}
.sim-mode-badge{font-family:var(--font-m);font-size:10px;padding:3px 9px;border-radius:3px;font-weight:500}
.sim-mode-badge.hist{background:var(--sepia-dim);color:var(--sepia)}
.sim-mode-badge.mod{background:var(--accent-dim);color:var(--accent-lt)}
.sim-nav{display:flex;gap:2px}
.snb{background:none;border:none;color:var(--text2);font-family:var(--font-b);font-size:11px;font-weight:500;padding:5px 11px;cursor:pointer;border-radius:4px;transition:all .15s;text-transform:uppercase;letter-spacing:.4px}
.snb:hover{color:var(--text);background:var(--surface2)}
.snb.active{color:var(--accent-lt);background:var(--accent-dim)}
.ticker-wrap{flex:1;overflow:hidden;font-family:var(--font-m);font-size:11px}
.ticker-inner{display:flex;gap:18px;animation:tscrll 50s linear infinite;white-space:nowrap}
@keyframes tscrll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.t-sym{color:var(--text);font-weight:500}
.topbar-cash{font-family:var(--font-m);font-size:11px;color:var(--text2);flex-shrink:0}
.topbar-cash span{color:var(--green-lt);font-weight:500}

/* ─── SIM BODY ─── */
.sim-body{display:flex;height:calc(100vh - 46px)}
.sim-left{width:232px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column}
.sim-center{flex:1;overflow-y:auto}
.sim-right{width:268px;flex-shrink:0;background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column}

.pnl-hdr{padding:8px 13px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.pnl-ttl{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3)}
.pnl-badge{font-size:9px;background:var(--surface3);color:var(--text3);padding:2px 7px;border-radius:3px;font-family:var(--font-m)}

/* Stock rows */
.stk-row{padding:9px 13px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;display:flex;align-items:center;gap:9px}
.stk-row:hover{background:var(--surface2)}
.stk-row.sel{background:rgba(37,99,235,.08);border-left:2px solid var(--accent)}
.stk-ico{width:26px;height:26px;border-radius:5px;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--font-m)}
.stk-inf{flex:1;min-width:0}
.stk-sym{font-size:12px;font-weight:500}
.stk-exch{font-size:10px;color:var(--text3)}
.stk-prc-col{text-align:right;flex-shrink:0}
.stk-prc{font-family:var(--font-m);font-size:11px;font-weight:500}
.stk-chg{font-family:var(--font-m);font-size:10px}
.pos{color:var(--green-lt)}.neg{color:var(--red-lt)}.neu{color:var(--text2)}
.sec-div{padding:5px 13px;background:var(--bg);border-bottom:1px solid var(--border);font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3)}

/* Chart area */
.chart-area{padding:14px}
.sh-row{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
.sh-sym{font-family:var(--font-d);font-size:22px;font-weight:700;letter-spacing:-.5px}
.sh-name{font-size:12px;color:var(--text2);margin-top:2px}
.sh-meta{font-size:11px;color:var(--text3);margin-top:3px}
.price-big{font-family:var(--font-m);font-size:28px;font-weight:500;line-height:1}
.price-chg{font-family:var(--font-m);font-size:12px;margin-top:4px}

.chart-box{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:12px;margin-bottom:12px}
.tf-btns{display:flex;gap:4px;margin-bottom:10px}
.tf-btn{background:none;border:1px solid var(--border);color:var(--text3);font-size:10px;font-family:var(--font-m);padding:3px 8px;border-radius:3px;cursor:pointer;transition:all .15s}
.tf-btn:hover{border-color:var(--border2);color:var(--text2)}
.tf-btn.active{background:var(--accent-dim);border-color:var(--accent);color:var(--accent-lt)}
.tf-btn.hist-active{background:var(--sepia-dim);border-color:var(--sepia);color:var(--sepia)}
.chart-svg{width:100%;height:140px}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:9px 11px}
.stat-lbl{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;font-weight:600;margin-bottom:3px}
.stat-val{font-family:var(--font-m);font-size:13px;font-weight:500}

/* Era context banner */
.era-banner{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:12px 14px;margin-bottom:12px;border-left:3px solid var(--sepia)}
.era-banner.mod{border-left-color:var(--accent-lt)}
.era-banner-hdr{display:flex;align-items:center;gap:8px;margin-bottom:6px}
.era-banner-title{font-size:11px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;color:var(--text2)}
.era-context-text{font-size:12px;color:var(--text2);line-height:1.6;font-weight:300}

/* Reg impact */
.reg-impact{background:var(--surface);border:1px solid var(--border);border-radius:7px;padding:12px 14px;margin-bottom:12px}
.ri-hdr{display:flex;align-items:center;gap:8px;margin-bottom:9px}
.ri-title{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--text2);flex:1}
.ri-chip{font-size:9px;padding:2px 8px;border-radius:3px;font-family:var(--font-m);font-weight:600}
.ri-chip.active{background:var(--amber-dim);color:var(--amber-lt)}
.ri-chip.none{background:var(--surface2);color:var(--text3)}
.ri-effects{display:flex;gap:7px;flex-wrap:wrap}
.ri-pill{font-size:11px;padding:5px 10px;border-radius:4px;display:flex;align-items:center;gap:5px}
.ri-pill.down{background:var(--red-dim);color:var(--red-lt);border:1px solid rgba(220,38,38,.2)}
.ri-pill.up{background:var(--green-dim);color:var(--green-lt);border:1px solid rgba(5,150,105,.2)}

/* Right panel — trade */
.trade-tabs{display:flex;gap:4px;padding:9px 13px;border-bottom:1px solid var(--border)}
.trade-tab{flex:1;padding:6px;border:1px solid var(--border);background:none;font-family:var(--font-b);font-size:12px;font-weight:500;cursor:pointer;border-radius:4px;transition:all .15s;color:var(--text2)}
.trade-tab.buy.active{background:var(--green-dim);border-color:var(--green);color:var(--green-lt)}
.trade-tab.sell.active{background:var(--red-dim);border-color:var(--red);color:var(--red-lt)}
.trade-body{padding:11px 13px;border-bottom:1px solid var(--border)}
.fld-lbl{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:5px}
.fld-grp{margin-bottom:9px}
.qty-row{display:flex;gap:5px}
.qty-inp{background:var(--bg);border:1px solid var(--border);color:var(--text);font-family:var(--font-m);font-size:13px;padding:7px 9px;border-radius:4px;flex:1;outline:none;transition:border .15s}
.qty-inp:focus{border-color:var(--accent)}
.qty-pre{background:var(--surface2);border:1px solid var(--border);color:var(--text2);font-size:10px;font-family:var(--font-m);padding:4px 6px;border-radius:3px;cursor:pointer;transition:all .15s}
.qty-pre:hover{border-color:var(--accent-lt);color:var(--accent-lt)}
.trade-sum{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:9px;margin-bottom:9px}
.sum-row{display:flex;justify-content:space-between;font-size:11px;color:var(--text2);padding:2px 0}
.sum-row.total{color:var(--text);font-weight:500;border-top:1px solid var(--border);margin-top:4px;padding-top:5px}
.exec-btn{width:100%;padding:9px;border:none;border-radius:5px;font-family:var(--font-b);font-size:13px;font-weight:600;cursor:pointer;transition:all .15s}
.exec-btn.buy{background:var(--green);color:#fff}
.exec-btn.buy:hover{background:#047857}
.exec-btn.sell{background:var(--red);color:#fff}
.exec-btn.sell:hover{background:#b91c1c}
.exec-btn:disabled{opacity:.35;cursor:not-allowed}

.holding-row{padding:8px 13px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:7px}
.h-sym{font-family:var(--font-m);font-size:11px;font-weight:500;min-width:36px}
.h-inf{flex:1}.h-shares{font-size:10px;color:var(--text2)}.h-cost{font-size:10px;color:var(--text3)}
.h-right{text-align:right}.h-val{font-family:var(--font-m);font-size:11px;font-weight:500}
.h-pnl{font-family:var(--font-m);font-size:10px}
.empty-state{padding:22px;text-align:center;color:var(--text3);font-size:12px}

/* Regulations panel */
.reg-panel{}
.c-section{border-bottom:1px solid var(--border)}
.c-hdr{padding:11px 13px;cursor:pointer;display:flex;align-items:center;gap:9px;transition:background .15s}
.c-hdr:hover{background:var(--surface2)}
.c-flag{font-size:16px}
.c-name{font-size:12px;font-weight:500;flex:1}
.c-act-count{font-family:var(--font-m);font-size:10px;color:var(--amber-lt)}
.c-arr{font-size:11px;color:var(--text3);transition:transform .2s}
.c-arr.open{transform:rotate(90deg)}
.reg-list{padding:0 13px 10px;display:none}
.reg-list.open{display:block}
.reg-item{padding:9px 11px;background:var(--bg);border:1px solid var(--border);border-radius:6px;margin-top:7px}
.reg-item-top{display:flex;align-items:center;gap:7px;margin-bottom:5px}
.reg-name{font-size:11px;font-weight:500;flex:1}
.reg-toggle{position:relative;width:34px;height:19px;flex-shrink:0}
.reg-toggle input{opacity:0;width:0;height:0;position:absolute}
.tog-track{position:absolute;inset:0;background:var(--border2);border-radius:10px;cursor:pointer;transition:background .2s}
.tog-thumb{position:absolute;width:13px;height:13px;background:#fff;border-radius:50%;top:3px;left:3px;transition:transform .2s;pointer-events:none}
.reg-toggle input:checked~.tog-track{background:var(--amber)}
.reg-toggle input:checked~.tog-track~.tog-thumb{transform:translateX(15px)}
.reg-desc{font-size:11px;color:var(--text2);line-height:1.55;margin-bottom:7px;font-weight:300}
.reg-impacts{display:flex;flex-direction:column;gap:3px}
.imp-row{display:flex;align-items:center;gap:5px;font-size:10px}
.imp-sym{font-family:var(--font-m);font-weight:500;flex:1;color:var(--text2)}
.imp-val{font-family:var(--font-m);font-size:10px;font-weight:500}
.imp-val.down{color:var(--red-lt)}.imp-val.up{color:var(--green-lt)}

/* Portfolio + Leaderboard views */
.sim-view{display:none;height:calc(100vh - 46px);overflow-y:auto}
.sim-view.active{display:block}

.port-wrap{padding:18px;max-width:880px;margin:0 auto}
.port-stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:16px}
.psc{background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:11px 13px}
.psc-l{font-size:9px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;font-weight:700;margin-bottom:4px}
.psc-v{font-family:var(--font-m);font-size:15px;font-weight:500}
.psc-s{font-family:var(--font-m);font-size:10px;margin-top:2px}
.port-card{background:var(--surface);border:1px solid var(--border);border-radius:7px;overflow:hidden;margin-bottom:13px}
.pc-hdr{padding:9px 13px;border-bottom:1px solid var(--border)}
.pc-title{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text3)}
.ptable{width:100%;border-collapse:collapse}
.ptable th{padding:7px 13px;text-align:left;font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);border-bottom:1px solid var(--border)}
.ptable th:not(:first-child){text-align:right}
